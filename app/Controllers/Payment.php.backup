    }

    /**
     * Debug endpoint untuk test Nextcloud connection
     */
    public function debugNextcloud()
    {
        try {
            if (!session()->get('isLoggedIn')) {
                return $this->response->setJSON([
                    'status' => 401,
                    'message' => 'Unauthorized'
                ]);
            }

            $filename = $this->request->getVar('filename') ?? 'test.pdf';
            
            // Test download
            $result = $this->downloadFromNextcloud($filename);
            
            $response = [
                'filename' => $filename,
                'success' => $result['success'],
                'error' => $result['error'] ?? null,
                'size' => $result['size'] ?? null,
                'content_type' => $result['content_type'] ?? null
            ];
            
            if ($result['success']) {
                // Jangan return content untuk debug JSON, cukup metadata
                $response['message'] = 'PDF berhasil di-download dari Nextcloud';
                $response['pdf_valid'] = true;
            }
            
            return $this->response->setJSON($response);
            
        } catch (\Exception $e) {
            return $this->response->setJSON([
                'status' => 500,
                'error' => $e->getMessage()
            ]);
        }
    }

    /**
     * Check if user's slip gaji is in ACC folder
     */
    public function checkAccStatus()
    {
        try {
            if (!session()->get('isLoggedIn')) {
                return $this->response->setJSON(['success' => false, 'message' => 'Unauthorized']);
            }

            $userId = session()->get('id');

            // Get slip data
            $slipGajiModel = new SlipGajiModel();
            $slip = $slipGajiModel->getSentSlip($userId);

            if (!$slip) {
                return $this->response->setJSON(['success' => false, 'message' => 'No slip found']);
            }

            $filename = $slip['filename'];

            // Check if file exists in ACC folder
            $nextcloudBase = "https://cloud.daftartugasku.my.id/remote.php/dav/files/masterraden";
            $accPath = "/workflow/Report/acc/" . urlencode($filename);
            $nextcloudUser = "masterraden";
            $nextcloudPassword = "masterraden";

            $ch = curl_init();
            curl_setopt($ch, CURLOPT_URL, $nextcloudBase . $accPath);
            curl_setopt($ch, CURLOPT_USERPWD, $nextcloudUser . ':' . $nextcloudPassword);
            curl_setopt($ch, CURLOPT_CUSTOMREQUEST, 'HEAD');
            curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
            curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, false);
            curl_setopt($ch, CURLOPT_SSL_VERIFYHOST, false);
            curl_setopt($ch, CURLOPT_TIMEOUT, 10);
            curl_setopt($ch, CURLOPT_HTTPAUTH, CURLAUTH_BASIC);

            $response = curl_exec($ch);
            $httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
            $curlError = curl_error($ch);
            $errno = curl_errno($ch);

            curl_close($ch);

            if ($errno !== 0) {
                log_message('error', "Curl Error checking ACC status ($errno): $curlError");
                return $this->response->setJSON(['success' => false, 'message' => 'Error checking file status']);
            }

            $isInAcc = ($httpCode === 200);

            return $this->response->setJSON([
                'success' => true,
                'is_in_acc' => $isInAcc,
                'filename' => $filename
            ]);

        } catch (\Exception $e) {
            log_message('error', 'Payment::checkAccStatus - ' . $e->getMessage());
            return $this->response->setJSON(['success' => false, 'message' => 'Error: ' . $e->getMessage()]);
        }
    }
