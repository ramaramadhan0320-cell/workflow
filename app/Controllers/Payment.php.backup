    /**
     * Check jika user eligible untuk withdrawal
     * Kondisi:
     * 1. Sudah hari terakhir bulan (28/29/30/31)
     * 2. Hari tersebut bukan Sabtu/Minggu
     * 3. User sudah absen pada hari tersebut
     */
    private function checkWithdrawalEligibility($userId)
    {
        $today = date('Y-m-d');
        $dayOfMonth = (int)date('d');
        $daysInMonth = cal_days_in_month(CAL_GREGORIAN, (int)date('m'), (int)date('Y'));
        $dayOfWeek = (int)date('w'); // 0 = Sunday, 6 = Saturday
        
        // Cek apakah hari ini adalah hari terakhir bulan
        if ($dayOfMonth !== $daysInMonth) {
            return [
                'eligible' => false,
                'reason' => 'Bukan hari terakhir bulan. Hari terakhir bulan: ' . $daysInMonth
            ];
        }
        
        // Cek apakah hari terakhir bulan bukan Sabtu/Minggu
        if ($dayOfWeek == 0 || $dayOfWeek == 6) {
            return [
                'eligible' => false,
                'reason' => 'Hari terakhir bulan jatuh pada hari libur (Sabtu/Minggu)'
            ];
        }
        
        // Cek apakah user sudah absen hari ini
        try {
            $kehadiranModel = new KehadiranModel();
            $absenHariIni = $kehadiranModel->where('user_id', $userId)
                                          ->where('tanggal', $today)
                                          ->first();
            
            if (!$absenHariIni) {
                return [
                    'eligible' => false,
                    'reason' => 'Anda belum absen untuk hari terakhir bulan'
                ];
            }
        } catch (\Exception $e) {
            return [
                'eligible' => false,
                'reason' => 'Error checking attendance: ' . $e->getMessage()
            ];
        }
        
        return ['eligible' => true];
    }

    /**
     * Menampilkan slip gaji untuk dikirim
     */
    public function slip()
    {
        try {
