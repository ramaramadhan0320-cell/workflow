            return view('payment-slip', $data);
        } catch (\Exception $e) {
            log_message('error', 'Payment::slip - ' . $e->getMessage());
            return redirect()->to('/payment')->with('error', 'Error loading slip page: ' . $e->getMessage());
        }
    }

    /**
     * Kirim slip gaji ke Nextcloud sebagai PDF
     */
    public function sendSlip()
    {
        try {
            if (!session()->get('isLoggedIn')) {
                return $this->response->setJSON([
                    'status' => 401,
                    'message' => 'Unauthorized'
                ]);
            }

            $userId = session()->get('id');
            
            // TODO: Aktifkan eligibility check ketika sudah final
            // Cek eligibility
            // $eligibility = $this->checkWithdrawalEligibility($userId);
            // if (!$eligibility['eligible']) {
            //     return $this->response->setJSON([
            //         'status' => 400,
            //         'message' => $eligibility['reason']
            //     ]);
            // }

            // Load user data untuk nama file
            $userModel = new UserModel();
            $user = $userModel->find($userId);
            
            if (!$user) {
                return $this->response->setJSON([
                    'status' => 400,
                    'message' => 'User tidak ditemukan'
                ]);
            }

            // Ambil PDF dari request
            $pdfDataUri = $this->request->getPost('pdfData');
            
            if (!$pdfDataUri) {
                return $this->response->setJSON([
                    'status' => 400,
                    'message' => 'PDF data tidak ditemukan'
                ]);
            }

            // Decode data URI ke binary dengan proper handling
            try {
                // Extract base64 string dari data URI
                $base64String = $pdfDataUri;
                if (strpos($base64String, 'data:application/pdf;base64,') === 0) {
                    $base64String = substr($base64String, strlen('data:application/pdf;base64,'));
                } elseif (strpos($base64String, 'data:application/octet-stream;base64,') === 0) {
                    // Alternative MIME type
                    $base64String = substr($base64String, strlen('data:application/octet-stream;base64,'));
                } else {
                    // Coba cari 'base64,' di string
                    $parts = explode('base64,', $base64String);
                    if (count($parts) > 1) {
                        $base64String = $parts[1];
                    }
                }
                
                // Clean base64 string - remove whitespace dan special chars
                $base64String = preg_replace('/\s+/', '', $base64String);
                $base64String = preg_replace('/[^A-Za-z0-9+\/=]/', '', $base64String);
                
                // Add padding if needed
                $missing_padding = strlen($base64String) % 4;
                if ($missing_padding) {
                    $base64String .= str_repeat('=', 4 - $missing_padding);
                }
                
                $base64Length = strlen($base64String);
                log_message('info', "Processing base64 - Original request size: " . strlen($pdfDataUri) . " chars, After cleanup: $base64Length chars");
                
                // Try decode without strict mode first
                $pdfBinary = base64_decode($base64String, false);
                
                if ($pdfBinary === false || empty($pdfBinary)) {
                    log_message('error', "Base64 decode failed - trying strict mode");
                    // Try dengan strict mode
                    $pdfBinary = base64_decode($base64String, true);
                    if ($pdfBinary === false) {
                        throw new \Exception("Base64 decode gagal");
                    }
                }
                
                $binarySize = strlen($pdfBinary);
                log_message('info', "PDF binary size: " . $binarySize . " bytes");
                
                if ($binarySize === 0) {
                    throw new \Exception("PDF binary kosong setelah decode");
                }
                
                // Log first 20 bytes as hex untuk debugging
                $headerHex = bin2hex(substr($pdfBinary, 0, 20));
                log_message('info', "PDF header (hex): " . $headerHex);
                
                // Validate PDF header - more lenient approach
                $header = substr($pdfBinary, 0, 4);
                if ($header !== '%PDF') {
                    log_message('warning', "PDF header tidak standar. Expected '%PDF', got: '" . $header . "'");
                    
                    // Check if it's at least starting with % which suggests PDF format
                    if ($binarySize < 4) {
                        throw new \Exception("PDF file terlalu kecil (hanya $binarySize bytes)");
                    }
                    
                    // If minimal structure looks PDF-ish, continue
                    if (substr($header, 0, 1) !== '%') {
                        throw new \Exception("File signature tidak cocok (expected '%', got '" . substr($header, 0, 1) . "')");
                    }
                }
                
                log_message('info', "PDF validation passed!");
                
            } catch (\Exception $e) {
                log_message('error', "Exception in PDF decode: " . $e->getMessage());
                return $this->response->setJSON([
                    'status' => 400,
                    'message' => 'Error decode PDF: ' . $e->getMessage() . ' (Size: ' . strlen($pdfBinary ?? '') . ' bytes)'
                ]);
            }

            // Generate nama file
            $username = (string)($user['username'] ?? 'USER');
            $fileName = 'SLIP_GAJI_' . strtoupper($username) . '_' . date('Ymd_His') . '.pdf';
            
            // Upload ke Nextcloud WebDAV
            $nextcloudUrl = "https://cloud.daftartugasku.my.id/remote.php/dav/files/masterraden/workflow/Report/" . urlencode($fileName);
            $nextcloudUser = "masterraden";
            $nextcloudPassword = "masterraden";

            // Gunakan cURL untuk upload
            $ch = curl_init();
            
            curl_setopt($ch, CURLOPT_URL, $nextcloudUrl);
            curl_setopt($ch, CURLOPT_USERPWD, $nextcloudUser . ':' . $nextcloudPassword);
            curl_setopt($ch, CURLOPT_CUSTOMREQUEST, 'PUT');
            curl_setopt($ch, CURLOPT_BINARYTRANSFER, true);
            curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
            curl_setopt($ch, CURLOPT_POST, false);
            curl_setopt($ch, CURLOPT_POSTFIELDS, $pdfBinary);
            curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, false);
            curl_setopt($ch, CURLOPT_SSL_VERIFYHOST, false);
            curl_setopt($ch, CURLOPT_TIMEOUT, 60);
            curl_setopt($ch, CURLOPT_VERBOSE, false);

            // Set Content-Length header
            $headers = [
                'Content-Type: application/pdf',
                'Content-Length: ' . strlen($pdfBinary)
            ];
            curl_setopt($ch, CURLOPT_HTTPHEADER, $headers);

            $response = curl_exec($ch);
            $httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
            $curlError = curl_error($ch);
            $curlErrno = curl_errno($ch);

            curl_close($ch);

            // Log untuk debugging
            log_message('info', "Upload to Nextcloud - HTTP Code: $httpCode, File: $fileName, Size: " . strlen($pdfBinary) . " bytes");
            if ($curlError) {
                log_message('error', "Curl Error [$curlErrno]: $curlError");
            }

            // Check status upload
            if ($httpCode == 201 || $httpCode == 204) {
                // Save record ke database
                try {
                    $slipGajiModel = new SlipGajiModel();
                    $slipGajiModel->markAsSent($userId, $fileName);
                    log_message('info', "Slip record saved for user $userId");
                } catch (\Exception $e) {
                    log_message('error', 'Error saving slip record: ' . $e->getMessage());
                    // Tetap return success meski save record gagal
                }

                return $this->response->setJSON([
                    'status' => 200,
                    'message' => 'Slip gaji berhasil dikirim ke cloud',
                    'fileName' => $fileName,
                    'httpCode' => $httpCode
                ]);
            } else {
                $errorMsg = "Upload ke Nextcloud gagal (HTTP: $httpCode)";
                
                if ($httpCode == 401) {
                    $errorMsg = "Authentication gagal - periksa username/password Nextcloud";
                } elseif ($httpCode == 404) {
                    $errorMsg = "Folder /workflow/Report tidak ditemukan di Nextcloud";
                } elseif ($httpCode == 409) {
                    $errorMsg = "Folder /workflow/Report tidak ada di Nextcloud. Buat folder terlebih dahulu.";
                } elseif ($httpCode == 507) {
                    $errorMsg = "Storage Nextcloud penuh";
                }
                
                if ($curlError) {
                    $errorMsg .= " (Error: $curlError)";
                }

                log_message('error', "Upload failed: $errorMsg");
                
                return $this->response->setJSON([
                    'status' => 500,
                    'message' => $errorMsg,
                    'http_code' => $httpCode,
                    'debug' => $curlError
                ]);
            }
        } catch (\Exception $e) {
            log_message('error', 'Payment::sendSlip - ' . $e->getMessage());
            return $this->response->setJSON([
                'status' => 500,
                'message' => 'Error: ' . $e->getMessage()
            ]);
        }
    }

    /**
     * Calculate withdrawal date - last day of current month
     * If last day is Saturday/Sunday, find last working day before that
     */
    private function calculateWithdrawalDate()
    {
        $year = (int)date('Y');
        $month = (int)date('m');
        $daysInMonth = cal_days_in_month(CAL_GREGORIAN, $month, $year);
        
        // Start from last day of month
        $date = new \DateTime("$year-$month-$daysInMonth");
        $dayOfWeek = (int)$date->format('w'); // 0 = Sunday, 6 = Saturday
        
        // Keep going back if it's weekend (0 = Sunday, 6 = Saturday)
        while ($dayOfWeek == 0 || $dayOfWeek == 6) {
            $date->modify('-1 day');
            $dayOfWeek = (int)$date->format('w');
        }
        
        return $date->format('d/m/Y');
    }

    /**
     * Check if user can withdraw
     * Conditions:
     * 1. Today must be the withdrawal date (last working day of month)
     * 2. User must have submitted attendance for that day
     */
    private function canUserWithdraw($userId, $withdrawalDate)
    {
        try {
            // Convert withdrawal_date format (d/m/Y) to Y-m-d for comparison
            $withdrawalDateTime = \DateTime::createFromFormat('d/m/Y', $withdrawalDate);
            $withdrawalDateFormatted = $withdrawalDateTime->format('Y-m-d');
            $today = date('Y-m-d');

            // Check if today is withdrawal date
            if ($today !== $withdrawalDateFormatted) {
                return false;
            }

            // Check if user has attendance record for today
            $kehadiranModel = new KehadiranModel();
            $attendanceRecord = $kehadiranModel->where('user_id', $userId)
                                               ->where('tanggal', $today)
                                               ->first();

            return $attendanceRecord !== null;
        } catch (\Exception $e) {
            log_message('error', 'Error checking withdrawal eligibility: ' . $e->getMessage());
            return false;
        }
    }

    /**
     * Get slip gaji data dari database untuk preview modal
     */
    public function getSlipData()
    {
        try {
            if (!session()->get('isLoggedIn')) {
                return $this->response->setJSON([
                    'status' => 401,
                    'message' => 'Unauthorized'
                ]);
            }

            $userId = session()->get('id');
            
            // Get slip dari database
            $slipGajiModel = new SlipGajiModel();
            $sentSlip = $slipGajiModel->getSentSlip($userId);
            
            if (!$sentSlip) {
                return $this->response->setJSON([
                    'status' => 404,
                    'message' => 'Tidak ada slip gaji yang dikirim'
                ]);
            }
            
            return $this->response->setJSON([
                'status' => 200,
                'data' => [
                    'filename' => $sentSlip['filename'],
                    'sent_at' => $sentSlip['sent_at'],
                    'status' => $sentSlip['status']
                ]
            ]);
        } catch (\Exception $e) {
            log_message('error', 'Payment::getSlipData - ' . $e->getMessage());
            return $this->response->setJSON([
                'status' => 500,
                'message' => 'Error: ' . $e->getMessage()
            ]);
        }
    }

    /**
     * Get PDF as base64 untuk modal preview
     * Parameter: filename=slip_filename.pdf
     */
    public function getSlipPdfBase64()
    {
        try {
            if (!session()->get('isLoggedIn')) {
                return $this->response->setJSON([
                    'status' => 401,
                    'message' => 'Unauthorized'
                ]);
            }

            $userId = session()->get('id');
            $filename = $this->request->getVar('filename');
            
            if (!$filename) {
                return $this->response->setJSON([
                    'status' => 400,
                    'message' => 'Filename tidak ditemukan'
                ]);
            }
            
            // Validate - user hanya bisa access file mereka
            $slipGajiModel = new SlipGajiModel();
            $sentSlip = $slipGajiModel->getSentSlip($userId);
            
            if (!$sentSlip || $sentSlip['filename'] !== $filename) {
                return $this->response->setJSON([
                    'status' => 403,
                    'message' => 'Anda tidak memiliki akses ke file ini'
                ]);
            }
            
            // Download dari Nextcloud
            $downloadResult = $this->downloadFromNextcloud($filename);
            
            if (!$downloadResult['success']) {
                return $this->response->setJSON([
                    'status' => 500,
                    'message' => 'Gagal load file dari cloud'
                ]);
            }

            // Convert to base64
            $pdfBase64 = base64_encode($downloadResult['content']);
            
            return $this->response->setJSON([
                'status' => 200,
                'data' => [
                    'base64' => $pdfBase64,
                    'filename' => $filename
                ]
            ]);
            
        } catch (\Exception $e) {
            log_message('error', 'Payment::getSlipPdfBase64 - ' . $e->getMessage());
            return $this->response->setJSON([
                'status' => 500,
                'message' => 'Error: ' . $e->getMessage()
            ]);
        }
    }

    /**
     * Download slip gaji dari Nextcloud
     */
    public function downloadSlip()
    {
        try {
            if (!session()->get('isLoggedIn')) {
                return $this->response->setJSON([
                    'status' => 401,
                    'message' => 'Unauthorized'
                ]);
            }

            $userId = session()->get('id');
            $filename = $this->request->getVar('filename');
            
            if (!$filename) {
                return $this->response->setJSON([
                    'status' => 400,
                    'message' => 'Filename tidak ditemukan'
                ]);
            }
            
            // Validate filename - pastikan user hanya bisa download file mereka
            $slipGajiModel = new SlipGajiModel();
            $sentSlip = $slipGajiModel->getSentSlip($userId);
            
            if (!$sentSlip || $sentSlip['filename'] !== $filename) {
                return $this->response->setJSON([
                    'status' => 403,
                    'message' => 'Anda tidak memiliki akses ke file ini'
                ]);
            }
            
            // Download dari Nextcloud menggunakan helper method
            $downloadResult = $this->downloadFromNextcloud($filename);
            
            if (!$downloadResult['success']) {
                return $this->response->setJSON([
                    'status' => 500,
                    'message' => 'Gagal download file dari cloud: ' . $downloadResult['error']
                ]);
            }

            $fileContent = $downloadResult['content'];

            // Return file as download
            return $this->response
                ->setHeader('Content-Type', 'application/pdf')
                ->setHeader('Content-Disposition', 'attachment; filename="' . $filename . '"')
                ->setHeader('Content-Length', strlen($fileContent))
                ->setBody($fileContent);
                
        } catch (\Exception $e) {
            log_message('error', 'Payment::downloadSlip - ' . $e->getMessage());
            return $this->response->setJSON([
                'status' => 500,
                'message' => 'Error: ' . $e->getMessage()
            ]);
        }
    }

    /**
     * Cache PDF untuk preview - store temp file dan return URL
     */
    private function cachePdfAndGetUrl($filename, $fileContent)
    {
        try {
            $tempDir = WRITEPATH . 'uploads/temp_pdf_cache/';
            
            // Create directory jika belum ada
            if (!is_dir($tempDir)) {
                @mkdir($tempDir, 0777, true);
            }
            
            // Generate unique cache filename
            $cacheFilename = md5($filename . time()) . '.pdf';
            $cachePath = $tempDir . $cacheFilename;
            
            // Write to cache dengan validasi
            $bytesWritten = file_put_contents($cachePath, $fileContent, LOCK_EX);
            $expectedSize = strlen($fileContent);
            
            if ($bytesWritten === false || $bytesWritten !== $expectedSize) {
                log_message('error', "Cache write failed for $filename: got $bytesWritten bytes, expected $expectedSize");
                return [
                    'success' => false,
                    'error' => 'Failed to write cache file'
                ];
            }
            
            // Verify file exists and has correct size
            if (!file_exists($cachePath) || filesize($cachePath) !== $expectedSize) {
                log_message('error', "Cache file verification failed for $filename");
                return [
                    'success' => false,
                    'error' => 'Cache file verification failed'
                ];
            }
            
            log_message('info', "Cache file created: $cacheFilename ($expectedSize bytes)");
            
            // Create serving URL via CodeIgniter route with download() method
            return [
                'success' => true,
                'cache_url' => base_url('payment/serve-cached-pdf') . '?file=' . urlencode($cacheFilename),
                'cache_path' => $cachePath,
                'cache_filename' => $cacheFilename
            ];
        } catch (\Exception $e) {
            log_message('error', 'Cache PDF error: ' . $e->getMessage());
            return [
                'success' => false,
                'error' => $e->getMessage()
            ];
        }
    }

    /**
     * Get slip gaji PDF untuk preview (streaming, tidak download)
     */
    public function getSlipPdf()
    {
        try {
            if (!session()->get('isLoggedIn')) {
                return $this->response->setJSON([
                    'status' => 401,
                    'message' => 'Unauthorized'
                ]);
            }

            $userId = session()->get('id');
            $filename = $this->request->getVar('filename');
            
            if (!$filename) {
                return $this->response->setJSON([
                    'status' => 400,
                    'message' => 'Filename tidak ditemukan'
                ]);
            }
            
            // Validate filename - pastikan user hanya bisa access file mereka
            $slipGajiModel = new SlipGajiModel();
            $sentSlip = $slipGajiModel->getSentSlip($userId);
            
            if (!$sentSlip || $sentSlip['filename'] !== $filename) {
                return $this->response->setJSON([
                    'status' => 403,
                    'message' => 'Anda tidak memiliki akses ke file ini'
                ]);
            }
            
            // Download dari Nextcloud menggunakan helper method
            $downloadResult = $this->downloadFromNextcloud($filename);
            
            if (!$downloadResult['success']) {
                return $this->response->setJSON([
                    'status' => 500,
                    'message' => 'Gagal load file dari cloud: ' . $downloadResult['error']
                ]);
            }

            $fileContent = $downloadResult['content'];
            $fileSize = $downloadResult['size'];

            // ALWAYS use cache URL untuk preview (lebih reliable daripada data URI)
            log_message('info', "Caching PDF for preview - Size: " . $fileSize . " bytes");
            
            $cacheResult = $this->cachePdfAndGetUrl($filename, $fileContent);
            if ($cacheResult['success']) {
                log_message('info', "PDF cached successfully at: " . $cacheResult['cache_path']);
                
                return $this->response->setJSON([
                    'status' => 200,
                    'data' => [
                        'pdf_url' => $cacheResult['cache_url'],
                        'filename' => $filename,
                        'use_url' => true
                    ]
                ]);
            } else {
                log_message('error', "Cache failed: " . $cacheResult['error']);
                return $this->response->setJSON([
                    'status' => 500,
                    'message' => 'Gagal cache PDF: ' . ($cacheResult['error'] ?? 'Unknown error')
                ]);
            }
                
        } catch (\Exception $e) {
            log_message('error', 'Payment::getSlipPdf - ' . $e->getMessage());
            return $this->response->setJSON([
                'status' => 500,
                'message' => 'Error: ' . $e->getMessage()
            ]);
        }
    }

    /**
     * Serve cached PDF file via PHP (untuk PDF.js preview atau download)
     * Parameter: file=filename.pdf, download=true (optional)
     */
    public function serveCachedPdf()
    {
        try {
            $filename = $this->request->getVar('file');
            $download = $this->request->getVar('download') === 'true';
            
            if (!$filename) {
                return 'File parameter required';
            }

            $cachePath = WRITEPATH . 'uploads/temp_pdf_cache/' . $filename;
            
            if (!file_exists($cachePath)) {
                return 'File not found: ' . $cachePath;
            }

            // Read file
            $content = file_get_contents($cachePath);
            if ($content === false) {
                return 'Failed to read file';
            }

            // Set headers sebelum output
            header('Content-Type: application/pdf', true);
            header('Content-Length: ' . strlen($content), true);
            header('Cache-Control: public, max-age=3600', true);
            
            if ($download) {
                header('Content-Disposition: attachment; filename="slip_gaji.pdf"', true);
            } else {
                header('Content-Disposition: inline; filename="slip_gaji.pdf"', true);
            }

            // Output file
            echo $content;
            exit;

        } catch (\Exception $e) {
            log_message('error', 'serveCachedPdf Exception: ' . $e->getMessage());
            return 'Error: ' . $e->getMessage();
        }
    }

    /**
     * Preview cached PDF dengan base64 embed langsung
     * Parameter: file=filename.pdf
     */
    public function previewSlip()
    {
        try {
