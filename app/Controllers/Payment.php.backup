            $pdfContent = file_get_contents($cachePath);
            if ($pdfContent === false) {
                return "Failed to read file";
            }

            // Convert to base64
            $pdfBase64 = base64_encode($pdfContent);
            $dataUri = 'data:application/pdf;base64,' . $pdfBase64;
            
            // Generate download URL
            $downloadUrl = base_url('payment/serve-cached-pdf') . '?file=' . urlencode($filename) . '&download=true';
            
            // Return HTML dengan PDF embed via base64
            $html = <<<HTML
