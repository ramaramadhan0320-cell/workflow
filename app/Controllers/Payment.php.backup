            width: auto;
            height: auto;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            border-radius: 4px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📄 Preview Slip Gaji</h1>
            <div class="controls">
                <button class="download-btn" onclick="downloadPdf()">📥 Download</button>
                <button class="close-btn" onclick="window.close()">Tutup</button>
